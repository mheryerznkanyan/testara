ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
RAG_PERSIST_DIR=./rag_store
RAG_COLLECTION=ios_app
RAG_EMBED_MODEL=BAAI/bge-base-en-v1.5
RAG_TOP_K=10
PORT=8000
HOST=0.0.0.0
PROJECT_ROOT=/path/to/your/ios/project

# Test credentials (auto-login for apps with login screens)
TEST_CREDENTIALS_EMAIL=
TEST_CREDENTIALS_PASSWORD=

# App bundle ID for Appium test execution
BUNDLE_ID=com.example.MyApp

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=testara
LANGSMITH_TRACING=false

# Appium (local test execution)
APPIUM_ENABLED=true
APPIUM_SERVER_URL=http://localhost:4723
APPIUM_STARTUP_TIMEOUT=30
APPIUM_DISCOVERY_TIMEOUT=60

# BrowserStack App Automate (cloud execution)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
BROWSERSTACK_APP_URL=              # bs://... URL from upload, or leave empty to auto-upload
BROWSERSTACK_DEVICE=iPhone 14
BROWSERSTACK_OS_VERSION=16
BROWSERSTACK_IPA_PATH=             # path to .ipa file for auto-upload

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
